# === TEMPLATE — copiar a .env y rellenar con valores reales ===
# Para dev local:   DB_NAME=galeria_3d_local, user local
# Para prod:        las credenciales reales viven en el droplet (/var/www/galeria-api/.env)

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=galeria_3d_local
DB_USER=galeria_local
DB_PASS=***

# JWT — usar un secret DISTINTO al de prod para que los tokens no sean intercambiables
JWT_SECRET=cambiar-en-cada-entorno

# DigitalOcean Spaces (compartido entre dev y prod si se usa el mismo bucket)
SPACES_KEY=***
SPACES_SECRET=***
SPACES_BUCKET=galeria-3d-files
SPACES_REGION=nyc3
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_CDN=https://galeria-3d-files.nyc3.cdn.digitaloceanspaces.com

# Server
PORT=3000
NODE_ENV=development

# Resend (password reset emails) — OPCIONAL en Plan C operativo (link reset oculto en UI).
# Sin RESEND_API_KEY el backend loguea el link en consola (modo dev-fallback) y sigue respondiendo 200.
#
# Para RE-HABILITAR el reset self-service en el futuro:
#   1. Sacar key desde https://resend.com/api-keys
#   2. Rellenar RESEND_API_KEY acá (y en /var/www/galeria-api/.env del droplet)
#   3. Descomentar el bloque en src/components/AuthModal.tsx (link "¿Olvidaste tu contraseña?")
#   4. Reiniciar backend + build/release frontend
#   5. Precondición: IT El Bosque debe whitelistar ceopacademia.org en Office 365
#      (el dominio está verificado en Resend, DKIM+SPF OK, pero la U dropea por reputación)
#   6. Precondición: Resend Pro plan (free está capado a 5 emails/día, 5/mes)
RESEND_API_KEY=re_***
# Remitente: en prod usar noreply@ceopacademia.org (dominio ya verificado en Resend).
# En dev `onboarding@resend.dev` funciona sin verificar dominio.
RESEND_FROM=Galeria 3D <noreply@ceopacademia.org>

# URL base del frontend (para construir links del email de reset)
APP_URL=http://localhost:5173
